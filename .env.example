DISCORD_TOKEN=your_discord_bot_token_here
CLIENT_ID=your_discord_client_id_here
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: have yt-dlp read YouTube cookies from your browser to avoid
# "sign in to confirm you're not a bot" errors. Use a throwaway Google account.
# Supported: chrome, firefox, edge, safari, brave, chromium, opera, vivaldi, whale
# YT_COOKIES_FROM_BROWSER=chrome
