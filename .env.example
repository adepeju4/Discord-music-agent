DISCORD_TOKEN=your_discord_bot_token_here
CLIENT_ID=your_discord_client_id_here
GEMINI_API_KEY=your_gemini_api_key_here

# YouTube auth (optional, but strongly recommended).
#
# Two options — YT_COOKIES_FILE takes precedence if both are set:
#
# 1. RECOMMENDED: file-based cookies, no Keychain prompts at runtime.
#    Run `npm run refresh-cookies` once (Keychain prompts once), then the
#    bot reads this file forever. Re-run when cookies expire (weeks-months).
# YT_COOKIES_FILE=/Users/your-username/.yt-cookies.txt
#
# 2. Direct browser cookies — simpler setup but prompts the macOS Keychain
#    every time yt-dlp is reinstalled/updated. Use a throwaway Google account.
#    Supported: chrome, firefox, edge, safari, brave, chromium, opera, vivaldi, whale
# YT_COOKIES_FROM_BROWSER=chrome
